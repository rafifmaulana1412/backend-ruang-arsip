generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                String    @id @default(uuid())
  name              String
  username          String    @unique
  email             String    @unique
  phone             String?
  is_active         Boolean   @default(true)
  is_restrict       Boolean   @default(false)
  password          String
  role_id           String
  division_id       String
  refresh_token     String?
  email_verified_at DateTime?
  password_set_at   DateTime?

  role               roles                @relation(fields: [role_id], references: [id])
  division           divisions            @relation(fields: [division_id], references: [id])
  auth_action_tokens auth_action_tokens[]

  sent_dispositions     incoming_mail_dispositions[] @relation("SenderDisposition")
  received_dispositions incoming_mail_dispositions[] @relation("ReceiverDisposition")

  sent_memo_dispositions     memorandum_dispositions[] @relation("SenderMemoDisposition")
  received_memo_dispositions memorandum_dispositions[] @relation("ReceiverMemoDisposition")

  created_digital_documents digital_documents[] @relation("DigitalDocumentsCreator")
  updated_digital_documents digital_documents[] @relation("DigitalDocumentsUpdater")
  deleted_digital_documents digital_documents[] @relation("DigitalDocumentsDeleter")
  requested_digital_document_accesses digital_document_access_requests[] @relation("DigitalDocumentAccessRequester")
  owned_digital_document_accesses     digital_document_access_requests[] @relation("DigitalDocumentAccessOwner")
  acted_digital_document_accesses     digital_document_access_requests[] @relation("DigitalDocumentAccessActor")
  borrowed_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanBorrower")
  approved_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanApprover")
  rejected_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanRejector")
  handed_over_digital_document_loans  digital_document_loans[]           @relation("DigitalDocumentLoanHandOverActor")
  returned_digital_document_loans     digital_document_loans[]           @relation("DigitalDocumentLoanReturnActor")
  digital_document_activity_logs      digital_document_activity_logs[]   @relation("DigitalDocumentActivityActor")

  created_outgoing_mails outgoing_mails[] @relation("OutgoingMailsCreator")
  updated_outgoing_mails outgoing_mails[] @relation("OutgoingMailsUpdater")
  deleted_outgoing_mails outgoing_mails[] @relation("OutgoingMailsDeleter")

  created_memorandums memorandums[] @relation("MemorandumCreator")
  updated_memorandums memorandums[] @relation("MemorandumUpdater")
  deleted_memorandums memorandums[] @relation("MemorandumDeleter")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum auth_action_token_types {
  INVITE
  RESET_PASSWORD
}

enum disposition_statuses {
  NEW
  IN_PROGRESS
  COMPLETED
  FORWARDED
}

enum digital_document_access_request_statuses {
  PENDING
  APPROVED
  REJECTED
}

enum digital_document_loan_statuses {
  PENDING
  APPROVED
  REJECTED
  BORROWED
  RETURNED
}

enum digital_document_activity_actions {
  CREATED
  UPDATED
  STORAGE_MOVED
  DELETED
  ACCESS_REQUESTED
  ACCESS_APPROVED
  ACCESS_REJECTED
  LOAN_REQUESTED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_HANDED_OVER
  LOAN_RETURNED
}

model auth_action_tokens {
  id         String                  @id @default(uuid())
  user_id    String
  type       auth_action_token_types
  token_hash String                  @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime                @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, type])
  @@index([expires_at])
}

model roles {
  id          String       @id @default(uuid())
  name        String
  users       users[]
  roles_menus role_menus[]
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
}

model divisions {
  id          String        @id @default(uuid())
  name        String
  users       users[]
  incoming_mails incoming_mails[]
  memorandums memorandums[]
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
}

model menus {
  id        String       @id @default(uuid())
  name      String
  parent_id String?
  parent    String?
  children  String?
  icon      String?
  url       String?
  order     Int?
  roleMenus role_menus[]
}

model role_menus {
  id      String @id @default(uuid())
  role_id String
  menu_id String

  can_create Boolean @default(false)
  can_read   Boolean @default(false)
  can_update Boolean @default(false)
  can_delete Boolean @default(false)

  role roles @relation(fields: [role_id], references: [id])
  menu menus @relation(fields: [menu_id], references: [id])

  @@unique([role_id, menu_id])
}

model storage_offices {
  id         String             @id @default(uuid())
  code       String             @unique
  name       String
  cabinets   storage_cabinets[]
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
}

model storage_cabinets {
  id         String          @id @default(uuid())
  office_id  String
  code       String
  office     storage_offices @relation(fields: [office_id], references: [id])
  racks      storages[]
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@unique([office_id, code])
  @@index([office_id])
}

model storages {
  id         String   @id @default(uuid())
  cabinet_id String
  name       String
  capacity   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  cabinet storage_cabinets @relation(fields: [cabinet_id], references: [id])

  digital_documents                digital_documents[]
  digital_document_activity_logs_from digital_document_activity_logs[] @relation("DigitalDocumentActivityFromStorage")
  digital_document_activity_logs_to   digital_document_activity_logs[] @relation("DigitalDocumentActivityToStorage")

  @@unique([cabinet_id, name])
  @@index([cabinet_id])
}

model document_types {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  digital_documents digital_documents[]
}

model letter_priorities {
  id             String           @id @default(uuid())
  name           String
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  incoming_mails incoming_mails[]
  outgoing_mails outgoing_mails[]
}

model incoming_mails {
  id                  String            @id @default(uuid())
  letter_prioritie_id String
  division_id         String
  name                String
  receive_date        DateTime
  address             String
  mail_number         String
  regarding           String?
  description         String?
  file                String?
  status              Int               @default(0) //0 = new, 1=IN_PROGRESS, 2=COMPLETED, 3=OVERDUE
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  letter_prioritie    letter_priorities @relation(fields: [letter_prioritie_id], references: [id])
  division            divisions         @relation(fields: [division_id], references: [id])

  disposition_mails incoming_mail_dispositions[]
}

model dispositions {
  id         String   @id @default(uuid())
  name       String
  due_date   Int?
  created_at DateTime @default(now())
}

model incoming_mail_dispositions {
  id                String    @id @default(uuid())
  incoming_mails_id String
  sender_id         String?
  receiver_id       String
  parent_disposition_id String?
  note              String?
  start_date        DateTime?
  due_date          DateTime?
  status            disposition_statuses @default(NEW)
  is_complete       Boolean   @default(false)
  completed_at      DateTime?
  disposed_at       DateTime? @default(now())

  incoming_mail incoming_mails @relation(fields: [incoming_mails_id], references: [id], onDelete: Cascade)
  sender        users?         @relation("SenderDisposition", fields: [sender_id], references: [id])
  receiver      users          @relation("ReceiverDisposition", fields: [receiver_id], references: [id])
  parent_disposition incoming_mail_dispositions? @relation("IncomingMailDispositionChain", fields: [parent_disposition_id], references: [id], onDelete: SetNull)
  child_dispositions incoming_mail_dispositions[] @relation("IncomingMailDispositionChain")

  @@index([incoming_mails_id, status])
  @@index([parent_disposition_id])
}

model digital_documents {
  id              String   @id @default(uuid())
  storage_id      String
  is_restricted   Boolean  @default(false)
  document_type_id String
  document_number String   @unique
  document_name   String
  description     String?
  file            String?
  created_by      String
  updated_by      String?
  deleted_by      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  storage       storages       @relation(fields: [storage_id], references: [id])
  document_type document_types @relation(fields: [document_type_id], references: [id])

  creator users  @relation("DigitalDocumentsCreator", fields: [created_by], references: [id])
  updater users? @relation("DigitalDocumentsUpdater", fields: [updated_by], references: [id])
  deleter users? @relation("DigitalDocumentsDeleter", fields: [deleted_by], references: [id])

  access_requests digital_document_access_requests[]
  loans           digital_document_loans[]
  activity_logs   digital_document_activity_logs[]
}

model digital_document_access_requests {
  id             String                                 @id @default(uuid())
  document_id    String
  requester_id   String
  owner_id       String
  status         digital_document_access_request_statuses @default(PENDING)
  request_reason String
  action_note    String?
  expires_at     DateTime?
  acted_by       String?
  acted_at       DateTime?
  created_at     DateTime                               @default(now())
  updated_at     DateTime                               @updatedAt

  document  digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  requester users             @relation("DigitalDocumentAccessRequester", fields: [requester_id], references: [id])
  owner     users             @relation("DigitalDocumentAccessOwner", fields: [owner_id], references: [id])
  actor     users?            @relation("DigitalDocumentAccessActor", fields: [acted_by], references: [id])

  @@index([document_id, status])
  @@index([requester_id, status])
  @@index([owner_id, status])
}

model digital_document_loans {
  id                   String                       @id @default(uuid())
  document_id          String
  borrower_id          String
  status               digital_document_loan_statuses @default(PENDING)
  request_reason       String
  requested_start_date DateTime
  requested_due_date   DateTime
  approved_by          String?
  approved_at          DateTime?
  approval_note        String?
  rejected_by          String?
  rejected_at          DateTime?
  rejection_note       String?
  handed_over_by       String?
  handover_at          DateTime?
  handover_note        String?
  returned_by          String?
  returned_at          DateTime?
  return_note          String?
  created_at           DateTime                     @default(now())
  updated_at           DateTime                     @updatedAt

  document       digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  borrower       users             @relation("DigitalDocumentLoanBorrower", fields: [borrower_id], references: [id])
  approver       users?            @relation("DigitalDocumentLoanApprover", fields: [approved_by], references: [id])
  rejector       users?            @relation("DigitalDocumentLoanRejector", fields: [rejected_by], references: [id])
  handover_actor users?            @relation("DigitalDocumentLoanHandOverActor", fields: [handed_over_by], references: [id])
  return_actor   users?            @relation("DigitalDocumentLoanReturnActor", fields: [returned_by], references: [id])

  @@index([document_id, status])
  @@index([borrower_id, status])
  @@index([status, requested_due_date])
}

model digital_document_activity_logs {
  id              String                         @id @default(uuid())
  document_id     String
  actor_id        String?
  action          digital_document_activity_actions
  from_storage_id String?
  to_storage_id   String?
  reference_type  String?
  reference_id    String?
  description     String?
  created_at      DateTime                       @default(now())

  document     digital_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  actor        users?            @relation("DigitalDocumentActivityActor", fields: [actor_id], references: [id])
  from_storage storages?         @relation("DigitalDocumentActivityFromStorage", fields: [from_storage_id], references: [id])
  to_storage   storages?         @relation("DigitalDocumentActivityToStorage", fields: [to_storage_id], references: [id])

  @@index([document_id, created_at])
  @@index([action, created_at])
  @@index([from_storage_id])
  @@index([to_storage_id])
}

model outgoing_mails {
  id String @id @default(uuid())

  letter_prioritie_id String
  delivery_media      String
  name                String
  send_date           DateTime
  address             String
  mail_number         String
  file                String?
  status              Int       @default(0)
  created_by          String?
  updated_by          String?
  deleted_by          String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  creator          users?            @relation("OutgoingMailsCreator", fields: [created_by], references: [id])
  updater          users?            @relation("OutgoingMailsUpdater", fields: [updated_by], references: [id])
  deleter          users?            @relation("OutgoingMailsDeleter", fields: [deleted_by], references: [id])
  letter_prioritie letter_priorities @relation(fields: [letter_prioritie_id], references: [id])
}

model memorandums {
  id            String    @id @default(uuid())
  division_id   String
  memo_number   String
  memo_date     DateTime
  received_date DateTime
  due_date      DateTime?
  regarding     String?
  description   String?
  file          String?
  status        Int       @default(0) //0 = new, 1=COMPLETED (etc, logic based)

  created_by String?
  updated_by String?
  deleted_by String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  division divisions @relation(fields: [division_id], references: [id])

  creator users? @relation("MemorandumCreator", fields: [created_by], references: [id])
  updater users? @relation("MemorandumUpdater", fields: [updated_by], references: [id])
  deleter users? @relation("MemorandumDeleter", fields: [deleted_by], references: [id])

  dispositions memorandum_dispositions[]
}

model memorandum_dispositions {
  id             String    @id @default(uuid())
  memorandums_id String
  sender_id      String?
  receiver_id    String
  parent_disposition_id String?
  note           String?
  start_date     DateTime?
  due_date       DateTime?
  status         disposition_statuses @default(NEW)
  is_complete    Boolean   @default(false)
  completed_at   DateTime?
  disposed_at    DateTime? @default(now())

  memorandum memorandums @relation(fields: [memorandums_id], references: [id], onDelete: Cascade)
  sender     users?      @relation("SenderMemoDisposition", fields: [sender_id], references: [id])
  receiver   users       @relation("ReceiverMemoDisposition", fields: [receiver_id], references: [id])
  parent_disposition memorandum_dispositions? @relation("MemorandumDispositionChain", fields: [parent_disposition_id], references: [id], onDelete: SetNull)
  child_dispositions memorandum_dispositions[] @relation("MemorandumDispositionChain")

  @@index([memorandums_id, status])
  @@index([parent_disposition_id])
}
